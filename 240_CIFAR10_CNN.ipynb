      "source": [
        "## Model build\n",
        "\n",
        "### Custom Model\n",
        "\n",
        "- Output Size = (W - F + 2P) / S + 1  \n",
        "- output_size / Maxpool(2)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "metadata": {
        "id": "tepTfaI0mQJo"
      },
      "outputs": [],
      "source": [
        "def output_size(W, F, P, S, poolsize=1):\n",
        "    size = (W - F + 2*P)/S + 1\n",
        "    return size if poolsize == 1 else size / poolsize"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "qaFdOdKn4nIW"
      },
      "source": [
        "input image size : (32, 32)\n",
        "kernel size : 3\n",
        "padding : 1\n",
        "stride : 1"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "dehhRK5qmQJo",
        "outputId": "48bcfb8e-c63f-48d4-b05b-901609ac51e7"
      },
      "outputs": [
        {
          "output_type": "stream",
