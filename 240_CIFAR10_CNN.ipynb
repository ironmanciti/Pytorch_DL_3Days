    "    # 64개의 채널에 대해 배치 정규화 수행\n",
    "    nn.BatchNorm2d(64),\n",
    "    nn.ReLU(),\n",
    "    nn.MaxPool2d(2, 2),\n",
    "\n",
    "    # 텐서를 1차원으로 평탄화\n",
    "    nn.Flatten(),\n",
    "    # 드롭아웃을 적용하여 과적합 방지\n",
    "    nn.Dropout(0.25),\n",
    "    # 평탄화된 텐서를 받아 256개의 뉴런을 가진 레이어로 연결\n",
    "    nn.Linear(1024, 256),\n",
    "    # 완전 연결 레이어의 배치 정규화\n",
    "    nn.BatchNorm1d(256),\n",
    "    nn.ReLU(),\n",
    "    # 10개의 출력을 가진 레이어로 클래스 분류\n",
    "    nn.Linear(256, 10) # output: bs x 10\n",
    ")"
